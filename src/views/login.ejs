      <section class="form-card" aria-labelledby="login-heading">
        <p class="eyebrow">Account Access</p>
        <h1 id="login-heading">Login</h1>
        <p class="lead">Sign in to manage your account, saved vehicles, and dealership activity.</p>

        <% if (typeof error !== 'undefined' && error) { %>
          <p class="auth-form-summary auth-message auth-message-error" aria-live="polite"><%= error %></p>
        <% } %>

        <% if (typeof message !== 'undefined' && message) { %>
          <p class="auth-message auth-message-success"><%= message %></p>
        <% } %>

        <form class="auth-form" action="/login" method="post">
          <label class="field">
            <span>Email</span>
            <input
              type="email"
              name="email"
              autocomplete="email"
              value="<%= formData.email || '' %>"
              class="<%= fieldErrors && fieldErrors.email ? 'field-input is-invalid' : 'field-input' %>"
              aria-invalid="<%= fieldErrors && fieldErrors.email ? 'true' : 'false' %>"
              aria-describedby="login-email-error"
              required>
            <% if (fieldErrors && fieldErrors.email) { %>
              <span id="login-email-error" class="field-error"><%= fieldErrors.email %></span>
            <% } %>
          </label>

          <label class="field">
            <span>Password</span>
            <input
              type="password"
              name="password"
              autocomplete="current-password"
              class="<%= fieldErrors && fieldErrors.password ? 'field-input is-invalid' : 'field-input' %>"
              aria-invalid="<%= fieldErrors && fieldErrors.password ? 'true' : 'false' %>"
              aria-describedby="login-password-error"
              required>
            <% if (fieldErrors && fieldErrors.password) { %>
              <span id="login-password-error" class="field-error"><%= fieldErrors.password %></span>
            <% } %>
          </label>

          <button type="submit" class="auth-button">Log In</button>
        </form>

        <p class="auth-switch">Need an account? <a href="/register">Create one</a>.</p>
      </section>
