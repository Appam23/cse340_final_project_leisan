      <section class="auth-card admin-edit-card">
        <p class="admin-edit-banner">Staff area</p>
        <h1>Add Vehicle</h1>
        <p>Create a new vehicle listing for the inventory.</p>

        <% if (error) { %>
          <p class="auth-message auth-message-error"><%= error %></p>
        <% } %>

        <form action="/admin/inventory/new" method="post" class="auth-form">
          <label>
            Category
            <select name="categoryId" required>
              <option value="">Select a category</option>
              <% categories.forEach((category) => { %>
                <option value="<%= category.id %>" <%= String(formData.categoryId || '') === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
              <% }) %>
            </select>
          </label>

          <label>
            Year
            <input type="number" name="year" min="1900" max="2100" value="<%= formData.year || '' %>" required>
          </label>

          <label>
            Make
            <input type="text" name="make" value="<%= formData.make || '' %>" required>
          </label>

          <label>
            Model
            <input type="text" name="model" value="<%= formData.model || '' %>" required>
          </label>

          <label>
            Mileage
            <input type="number" name="mileage" min="0" value="<%= formData.mileage || '' %>" required>
          </label>

          <label>
            Description
            <textarea name="description" rows="4"><%= formData.description || '' %></textarea>
          </label>

          <label>
            Price
            <input type="number" name="price" min="0" step="0.01" value="<%= formData.price || '' %>" required>
          </label>

          <label>
            Image URL
            <input
              type="text"
              name="imageUrl"
              id="image-url-input"
              value="<%= formData.imageUrl || '' %>"
              placeholder="https://example.com/car.jpg or /images/car.png"
            >
            <small class="field-help">Use a direct image link or a site-relative path like /images/car.png.</small>
          </label>

          <div class="admin-image-preview-wrap">
            <p class="admin-image-preview-label">Image preview</p>
            <img
              id="admin-image-preview"
              class="admin-image-preview"
              src="<%= formData.imageUrl || '/images/car.png' %>"
              alt="Vehicle image preview"
            />
          </div>

          <label>
            <span>Availability</span>
            <select name="availability">
              <option value="on" <%= formData.availability !== false ? 'selected' : '' %>>Available</option>
              <option value="off" <%= formData.availability === false ? 'selected' : '' %>>Unavailable</option>
            </select>
          </label>

          <div class="auth-actions">
            <button type="submit" class="site-auth-button">Create Vehicle</button>
            <a class="site-auth-button" href="/admin/inventory">Cancel</a>
          </div>
        </form>
      </section>

<script src="/scripts/admin-inventory-preview.js" defer></script>
