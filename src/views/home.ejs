<!doctype html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/header') %>
    <main class="page">
      <p class="eyebrow">CSE340 Final Project</p>
      <a class="featured-car-link" href="<%= featuredCar.detailHref %>">
        <img class="car-photo" src="<%= featuredCar.src %>" alt="<%= featuredCar.title || 'Car photo' %>">
      </a>
      <h1>Car Dealership</h1>
      <p class="lead">Welcome to our car dealership website. Built with Node.js, Express, EJS, and PostgreSQL.</p>

      <section class="home-browse-categories" aria-labelledby="browse-categories-heading">
        <p class="api-kicker">Browse by Category</p>
        <h2 id="browse-categories-heading">Shop by Body Style</h2>
        <div class="home-category-grid">
          <% (browseCategories || []).forEach((category) => { %>
            <a class="home-category-link" href="<%= category.href %>"><%= category.label %></a>
          <% }) %>
        </div>
      </section>

      <section class="home-featured-vehicles" aria-labelledby="featured-vehicles-heading">
        <p class="api-kicker">Featured Vehicles</p>
        <h2 id="featured-vehicles-heading">Latest Available Inventory</h2>
        <% if (featuredVehicles && featuredVehicles.length) { %>
          <div class="home-featured-grid">
            <% featuredVehicles.forEach((vehicle) => { %>
              <a class="home-featured-card" href="<%= vehicle.detailHref %>">
                <img
                  class="home-featured-image"
                  src="<%= vehicle.image_url || '/images/car.png' %>"
                  alt="<%= vehicle.title %>"
                  data-fallback-src="/images/car.png"
                />
                <h3><%= vehicle.title %></h3>
                <p><%= vehicle.priceLabel %></p>
                <span>View details</span>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="api-meta">Featured vehicles will appear here as inventory is added.</p>
        <% } %>
      </section>

      <% if (currentUser && currentUser.role === 'owner') { %>
        <section class="form-card admin-tools" aria-labelledby="admin-tools-heading">
          <p class="api-kicker">Admin Tools</p>
          <h2 id="admin-tools-heading">Manage Users</h2>
          <p class="lead admin-tools-copy">Open the admin panel to update user info, change roles, or delete accounts.</p>
          <br>
          <div class="admin-actions">
            <a class="auth-button" href="/admin">Open Admin Panel</a>
          </div>
        </section>
      <% } %>

      <section class="api-card" aria-labelledby="api-heading">
        <p class="api-kicker">Live Car API</p>
        <h2 id="api-heading"><%= featuredCar.title %></h2>
        <p class="api-price"><%= featuredCar.price %></p>
        <p class="api-copy"><%= apiMessage %></p>
        <% if (carMakes && carMakes.length) { %>
          <div class="make-grid" aria-label="Random car makes">
            <% carMakes.forEach((make) => { %>
              <a
                class="make-pill make-link"
                href="https://www.google.com/search?q=<%= encodeURIComponent(make + ' car') %>"
                target="_blank"
                rel="noopener noreferrer"
              ><%= make %></a>
            <% }) %>
          </div>
          <p class="api-meta">Showing <%= carMakes.length %> random makes from <%= apiCount %> total.</p>
        <% } else { %>
          <p class="api-meta">No car makes loaded yet.</p>
        <% } %>
      </section>

      <% if (carImages && carImages.length) { %>
        <section class="gallery-card" aria-labelledby="gallery-heading">
          <p class="api-kicker">Live Car Images</p>
          <h2 id="gallery-heading">More Cars From the API</h2>
          <div class="gallery-grid">
            <% carImages.forEach((image) => { %>
              <a class="gallery-link" href="<%= image.detailHref %>">
                <figure class="gallery-item">
                  <img src="<%= image.src %>" alt="<%= image.title || 'Car image' %>">
                  <figcaption>
                    <span class="gallery-title"><%= image.title || 'Car image' %></span>
                    <span class="gallery-price"><%= image.price %></span>
                  </figcaption>
                </figure>
              </a>
            <% }) %>
          </div>
        </section>
      <% } else { %>
        <p class="api-meta">Image gallery could not load right now.</p>
      <% } %>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
