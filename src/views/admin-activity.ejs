<!doctype html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%
      const buildActivityLink = (overrides = {}) => {
        const params = new URLSearchParams({
          usersPage: String(usersPagination?.page || 1),
          servicePage: String(servicePagination?.page || 1),
          reviewsPage: String(reviewsPagination?.page || 1),
          contactsPage: String(contactsPagination?.page || 1),
          pageSize: String(pageSize || 5),
        });

        Object.entries(overrides).forEach(([key, value]) => {
          params.set(key, String(value));
        });

        return `/admin/activity?${params.toString()}`;
      };
    %>
    <%- include('partials/header') %>
    <main class="page">
      <section class="auth-card admin-panel">
        <p class="admin-edit-banner">Owner area</p>
        <h1>System Activity</h1>
        <p class="lead admin-panel-copy">Overview of user data and full platform activity across all major workflows.</p>

        <div class="admin-actions">
          <a class="auth-button" href="/admin">Owner Dashboard</a>
          <a class="auth-button" href="/admin/users">Manage Users</a>
        </div>

        <div class="admin-actions">
          <span class="admin-panel-copy">Rows per section:</span>
          <a class="admin-filter-chip <%= Number(pageSize) === 5 ? 'is-active' : '' %>" href="<%= buildActivityLink({ pageSize: 5 }) %>">5</a>
          <a class="admin-filter-chip <%= Number(pageSize) === 10 ? 'is-active' : '' %>" href="<%= buildActivityLink({ pageSize: 10 }) %>">10</a>
          <a class="admin-filter-chip <%= Number(pageSize) === 25 ? 'is-active' : '' %>" href="<%= buildActivityLink({ pageSize: 25 }) %>">25</a>
          <a class="admin-filter-chip <%= Number(pageSize) === 50 ? 'is-active' : '' %>" href="<%= buildActivityLink({ pageSize: 50 }) %>">50</a>
        </div>

        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Metric</th>
                <th>Count</th>
              </tr>
            </thead>
            <tbody>
              <tr><td data-label="Metric">Total users</td><td data-label="Count"><%= summary.users_total %></td></tr>
              <tr><td data-label="Metric">Owners</td><td data-label="Count"><%= summary.owners_total %></td></tr>
              <tr><td data-label="Metric">Employees</td><td data-label="Count"><%= summary.employees_total %></td></tr>
              <tr><td data-label="Metric">Customers</td><td data-label="Count"><%= summary.customers_total %></td></tr>
              <tr><td data-label="Metric">Categories</td><td data-label="Count"><%= summary.categories_total %></td></tr>
              <tr><td data-label="Metric">Vehicles</td><td data-label="Count"><%= summary.vehicles_total %></td></tr>
              <tr><td data-label="Metric">Reviews</td><td data-label="Count"><%= summary.reviews_total %></td></tr>
              <tr><td data-label="Metric">Service requests</td><td data-label="Count"><%= summary.service_requests_total %></td></tr>
              <tr><td data-label="Metric">Contact messages</td><td data-label="Count"><%= summary.contact_messages_total %></td></tr>
            </tbody>
          </table>
        </div>

        <h2 class="admin-activity-title">Users (<%= usersPagination.total %>)</h2>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
              </tr>
            </thead>
            <tbody>
              <% if (!users || users.length === 0) { %>
                <tr><td colspan="3">No users found.</td></tr>
              <% } else { %>
                <% users.forEach((user) => { %>
                  <tr>
                    <td data-label="Name"><%= user.name || 'N/A' %></td>
                    <td data-label="Email"><%= user.email %></td>
                    <td data-label="Role"><%= user.role %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
        <% if (usersPagination.totalPages > 1) { %>
          <div class="admin-pagination">
            <% if (usersPagination.page > 1) { %>
              <a class="admin-filter-chip" href="<%= buildActivityLink({ usersPage: usersPagination.page - 1 }) %>">Previous</a>
            <% } %>
            <span class="admin-panel-copy">Page <%= usersPagination.page %> of <%= usersPagination.totalPages %></span>
            <% if (usersPagination.page < usersPagination.totalPages) { %>
              <a class="admin-filter-chip" href="<%= buildActivityLink({ usersPage: usersPagination.page + 1 }) %>">Next</a>
            <% } %>
          </div>
        <% } %>

        <h2 class="admin-activity-title">Service Requests (<%= servicePagination.total %>)</h2>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Customer</th>
                <th>Vehicle</th>
                <th>Service</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (!serviceRequests || serviceRequests.length === 0) { %>
                <tr><td colspan="4">No service requests found.</td></tr>
              <% } else { %>
                <% serviceRequests.forEach((request) => { %>
                  <tr>
                    <td data-label="Customer"><%= request.user_name || 'N/A' %></td>
                    <td data-label="Vehicle"><%= request.vehicle_name || 'Unassigned vehicle' %></td>
                    <td data-label="Service"><%= request.service_type %></td>
                    <td data-label="Status"><%= request.status %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
        <% if (servicePagination.totalPages > 1) { %>
          <div class="admin-pagination">
            <% if (servicePagination.page > 1) { %>
              <a class="admin-filter-chip" href="<%= buildActivityLink({ servicePage: servicePagination.page - 1 }) %>">Previous</a>
            <% } %>
            <span class="admin-panel-copy">Page <%= servicePagination.page %> of <%= servicePagination.totalPages %></span>
            <% if (servicePagination.page < servicePagination.totalPages) { %>
              <a class="admin-filter-chip" href="<%= buildActivityLink({ servicePage: servicePagination.page + 1 }) %>">Next</a>
            <% } %>
          </div>
        <% } %>

        <h2 class="admin-activity-title">Reviews (<%= reviewsPagination.total %>)</h2>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Customer</th>
                <th>Vehicle</th>
                <th>Rating</th>
                <th>Comment</th>
              </tr>
            </thead>
            <tbody>
              <% if (!reviews || reviews.length === 0) { %>
                <tr><td colspan="4">No reviews found.</td></tr>
              <% } else { %>
                <% reviews.forEach((review) => { %>
                  <tr>
                    <td data-label="Customer"><%= review.user_name || 'N/A' %></td>
                    <td data-label="Vehicle"><%= review.vehicle_name || 'Unknown vehicle' %></td>
                    <td data-label="Rating"><%= review.rating %>/5</td>
                    <td data-label="Comment"><%= review.comment || 'No comment provided.' %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
        <% if (reviewsPagination.totalPages > 1) { %>
          <div class="admin-pagination">
            <% if (reviewsPagination.page > 1) { %>
              <a class="admin-filter-chip" href="<%= buildActivityLink({ reviewsPage: reviewsPagination.page - 1 }) %>">Previous</a>
            <% } %>
            <span class="admin-panel-copy">Page <%= reviewsPagination.page %> of <%= reviewsPagination.totalPages %></span>
            <% if (reviewsPagination.page < reviewsPagination.totalPages) { %>
              <a class="admin-filter-chip" href="<%= buildActivityLink({ reviewsPage: reviewsPagination.page + 1 }) %>">Next</a>
            <% } %>
          </div>
        <% } %>

        <h2 class="admin-activity-title">Contact Messages (<%= contactsPagination.total %>)</h2>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Subject</th>
                <th>Submitted</th>
              </tr>
            </thead>
            <tbody>
              <% if (!contactMessages || contactMessages.length === 0) { %>
                <tr><td colspan="4">No contact messages found.</td></tr>
              <% } else { %>
                <% contactMessages.forEach((entry) => { %>
                  <tr>
                    <td data-label="Name"><%= entry.name %></td>
                    <td data-label="Email"><%= entry.email %></td>
                    <td data-label="Subject"><%= entry.subject || 'General' %></td>
                    <td data-label="Submitted"><%= entry.created_at ? new Date(entry.created_at).toLocaleString('en-US') : '' %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
        <% if (contactsPagination.totalPages > 1) { %>
          <div class="admin-pagination">
            <% if (contactsPagination.page > 1) { %>
              <a class="admin-filter-chip" href="<%= buildActivityLink({ contactsPage: contactsPagination.page - 1 }) %>">Previous</a>
            <% } %>
            <span class="admin-panel-copy">Page <%= contactsPagination.page %> of <%= contactsPagination.totalPages %></span>
            <% if (contactsPagination.page < contactsPagination.totalPages) { %>
              <a class="admin-filter-chip" href="<%= buildActivityLink({ contactsPage: contactsPagination.page + 1 }) %>">Next</a>
            <% } %>
          </div>
        <% } %>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
