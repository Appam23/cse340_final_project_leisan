<header class="site-header">
  <a class="site-brand" href="/">
    <img class="site-logo" src="/images/appa.jpeg" alt="Appa logo">
    <span>Car Franchise</span>
  </a>
  <nav class="site-nav" aria-label="Primary">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <% if (currentUser) { %>
      <span class="site-user">
        Signed in as
        <%= [currentUser.first_name, currentUser.last_name].filter(Boolean).join(' ') || currentUser.email %>
      </span>
      <form class="site-auth-form" action="/logout" method="post">
        <button type="submit" class="site-auth-button">Logout</button>
      </form>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>
</header>
