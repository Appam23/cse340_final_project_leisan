<header class="site-header">
  <a class="site-brand" href="/">
    <img class="site-logo" src="/images/appa.jpeg" alt="Appa logo">
    <span>Car Franchise</span>
  </a>
  <nav class="site-nav" aria-label="Primary">
    <a href="/">Home</a>
    <% if (currentUser) { %>
      <a href="/inventory">Search by Category</a>
    <% } %>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <% if (currentUser) { %>
      <span class="site-user">
        Signed in as
        <%= currentUser.name || currentUser.email %>
      </span>
      <% if (['employee', 'owner'].includes(currentUser.role)) { %>
        <a href="/employee">Employee Dashboard</a>
      <% } %>
      <% if (currentUser.role === 'owner') { %>
        <a href="/admin">Admin</a>
      <% } %>
      <form class="site-auth-form" action="/logout" method="post">
        <button type="submit" class="site-auth-button">Logout</button>
      </form>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>
</header>
<% if (messages && messages.success && messages.success.length) { %>
  <% messages.success.forEach(m => { %>
    <div class="site-flash">
      <p class="auth-message auth-message-success"><%= m %></p>
    </div>
  <% }) %>
<% } %>

<% if (messages && messages.error && messages.error.length) { %>
  <% messages.error.forEach(m => { %>
    <div class="site-flash">
      <p class="auth-message auth-message-error"><%= m %></p>
    </div>
  <% }) %>
<% } %>
