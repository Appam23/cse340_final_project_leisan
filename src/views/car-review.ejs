<section class="detail-shell">
  <div class="detail-card">
          <p class="eyebrow">Vehicle Review</p>
          <h1><%= car.title %></h1>
          <p class="lead">Review the price, inspect the image, and send your contact information if you want us to follow up.</p>

          <% if (inquirySuccess) { %>
            <div class="detail-notice detail-notice-success"><%= inquirySuccess %></div>
          <% } %>

          <% if (inquiryError) { %>
            <div class="detail-notice detail-notice-error" role="alert" aria-live="polite">
              <strong><%= inquiryError %></strong>

              <% if (fieldErrors && Object.keys(fieldErrors).length) { %>
                <ul class="detail-error-list">
                  <% Object.values(fieldErrors).forEach((fieldError) => { %>
                    <li><%= fieldError %></li>
                  <% }) %>
                </ul>
              <% } %>
            </div>
          <% } %>

          <div class="detail-grid">
            <figure class="detail-figure">
              <img
                class="detail-image"
                src="<%= car.src || car.image_url || '/images/car.png' %>"
                alt="<%= car.title || 'Car image' %>"
              >
              <figcaption><%= car.attribution %></figcaption>
            </figure>

            <div class="detail-info">
              <p class="detail-label">Price</p>
              <p class="detail-price"><%= car.price %></p>
              <p class="detail-copy">This is a live listing preview built from the car gallery shown on the home page.</p>

              <% if (car.specs) { %>
                <div class="detail-specs">
                  <p class="detail-label">Vehicle Specs</p>
                  <dl class="detail-spec-grid">
                    <div>
                      <dt>Category</dt>
                      <dd><%= car.specs.category || 'N/A' %></dd>
                    </div>
                    <div>
                      <dt>Year</dt>
                      <dd><%= car.specs.year || 'N/A' %></dd>
                    </div>
                    <div>
                      <dt>Make / Model</dt>
                      <dd><%= [car.specs.make, car.specs.model].filter(Boolean).join(' ') || 'N/A' %></dd>
                    </div>
                    <div>
                      <dt>Mileage</dt>
                      <dd><%= car.specs.mileage != null ? `${Number(car.specs.mileage).toLocaleString('en-US')} mi` : 'N/A' %></dd>
                    </div>
                    <div>
                      <dt>Availability</dt>
                      <dd><%= car.specs.availability || 'N/A' %></dd>
                    </div>
                  </dl>
                  <% if (car.specs.description) { %>
                    <p class="detail-copy"><%= car.specs.description %></p>
                  <% } %>
                </div>
              <% } %>

              <form class="auth-form detail-form" action="/cars/<%= car.id %>" method="post">
                <div class="field rating-field">
                  <span>Star Rating</span>
                  <fieldset class="rating-group <%= fieldErrors && fieldErrors.rating ? 'is-invalid' : '' %>">
                    <legend class="sr-only">Select a rating from one to five stars</legend>
                    <% [5, 4, 3, 2, 1].forEach((star) => { %>
                      <input
                        class="rating-input"
                        type="radio"
                        id="rating-<%= star %>"
                        name="rating"
                        value="<%= star %>"
                        <%= String(formData.rating || '') === String(star) ? 'checked' : '' %>
                      >
                      <label class="rating-star" for="rating-<%= star %>">
                        <span class="rating-star-icon" aria-hidden="true">★</span>
                        <span class="sr-only"><%= star %> star<%= star === 1 ? '' : 's' %></span>
                      </label>
                    <% }) %>
                  </fieldset>
                  <% if (fieldErrors && fieldErrors.rating) { %>
                    <p class="field-error"><%= fieldErrors.rating %></p>
                  <% } %>
                </div>

                <div class="field">
                  <span>Name</span>
                  <input type="text" name="name" value="<%= formData.name || '' %>" placeholder="Your full name" required <%= fieldErrors && fieldErrors.name ? 'aria-invalid="true"' : '' %>>
                </div>

                <div class="field">
                  <span>Email</span>
                  <input type="email" name="email" value="<%= formData.email || '' %>" placeholder="you@example.com" required <%= fieldErrors && fieldErrors.email ? 'aria-invalid="true"' : '' %>>
                </div>

                <div class="field">
                  <span>Phone</span>
                  <input type="tel" name="phone" value="<%= formData.phone || '' %>" placeholder="(555) 123-4567" required <%= fieldErrors && fieldErrors.phone ? 'aria-invalid="true"' : '' %>>
                </div>

                <div class="field">
                  <span>Message</span>
                  <textarea name="message" rows="4" placeholder="Tell us how we can help"><%= formData.message || '' %></textarea>
                </div>

                <button class="auth-button" type="submit">Submit Contact Information</button>
                <a class="detail-back-link" href="/">Back to Gallery</a>
              </form>

              <p class="detail-fineprint">We will only use this information to follow up about this vehicle.</p>

              <section class="detail-reviews">
                <h2>Service Request</h2>

                <% if (serviceError) { %>
                  <div class="detail-notice detail-notice-error" role="alert" aria-live="polite">
                    <strong><%= serviceError %></strong>
                  </div>
                <% } %>

                <% if (!currentUser) { %>
                  <p class="detail-copy">Please <a href="/login">log in</a> to submit a service request.</p>
                <% } else { %>
                  <form class="auth-form detail-form" action="/cars/<%= car.id %>/service-requests" method="post">
                    <div class="field">
                      <span>Service Type</span>
                      <select name="serviceType" <%= serviceFieldErrors && serviceFieldErrors.serviceType ? 'aria-invalid="true"' : '' %>>
                        <option value="" <%= !serviceForm.serviceType ? 'selected' : '' %>>Select a service</option>
                        <option value="oil_change" <%= serviceForm.serviceType === 'oil_change' ? 'selected' : '' %>>Oil Change</option>
                        <option value="inspection" <%= serviceForm.serviceType === 'inspection' ? 'selected' : '' %>>Inspection</option>
                        <option value="tire_rotation" <%= serviceForm.serviceType === 'tire_rotation' ? 'selected' : '' %>>Tire Rotation</option>
                        <option value="brake_service" <%= serviceForm.serviceType === 'brake_service' ? 'selected' : '' %>>Brake Service</option>
                        <option value="other" <%= serviceForm.serviceType === 'other' ? 'selected' : '' %>>Other</option>
                      </select>
                      <% if (serviceFieldErrors && serviceFieldErrors.serviceType) { %>
                        <p class="field-error"><%= serviceFieldErrors.serviceType %></p>
                      <% } %>
                    </div>

                    <div class="field">
                      <span>Notes</span>
                      <textarea name="notes" rows="3" placeholder="Describe your service needs"><%= serviceForm.notes || '' %></textarea>
                    </div>

                    <button class="auth-button" type="submit">Submit Service Request</button>
                  </form>

                  <div class="detail-service-history">
                    <h3>Your Service History</h3>

                    <% if (serviceRequests && serviceRequests.length) { %>
                      <ul class="detail-error-list">
                        <% serviceRequests.forEach((request) => { %>
                          <li>
                            <strong><%= request.displayServiceType %></strong>
                            <span class="detail-copy">Status: <%= request.status %></span>
                            <% if (request.displayNotes) { %>
                              <p><%= request.displayNotes %></p>
                            <% } %>
                            <p class="detail-copy">Submitted <%= request.submitted_at ? new Date(request.submitted_at).toLocaleDateString('en-US') : 'recently' %></p>
                          </li>
                        <% }) %>
                      </ul>
                    <% } else { %>
                      <p class="detail-copy">You have not submitted any service requests for this vehicle yet.</p>
                    <% } %>
                  </div>
                <% } %>
              </section>

              <section class="detail-reviews">
                <h2>Customer Reviews</h2>

                <% if (reviewError) { %>
                  <div class="detail-notice detail-notice-error" role="alert" aria-live="polite">
                    <strong><%= reviewError %></strong>
                  </div>
                <% } %>

                <% if (!currentUser) { %>
                  <p class="detail-copy">Please <a href="/login">log in</a> to write, edit, or delete your own reviews.</p>
                <% } else { %>
                  <form class="auth-form detail-form" action="/cars/<%= car.id %>/reviews" method="post">
                    <div class="field rating-field">
                      <span>Your Rating</span>
                      <fieldset class="rating-group <%= reviewFieldErrors && reviewFieldErrors.rating ? 'is-invalid' : '' %>">
                        <legend class="sr-only">Select your rating from one to five stars</legend>
                        <% [5, 4, 3, 2, 1].forEach((star) => { %>
                          <input
                            class="rating-input"
                            type="radio"
                            id="review-rating-<%= star %>"
                            name="rating"
                            value="<%= star %>"
                            <%= String(reviewForm.rating || '') === String(star) ? 'checked' : '' %>
                          >
                          <label class="rating-star" for="review-rating-<%= star %>">
                            <span class="rating-star-icon" aria-hidden="true">★</span>
                            <span class="sr-only"><%= star %> star<%= star === 1 ? '' : 's' %></span>
                          </label>
                        <% }) %>
                      </fieldset>
                      <% if (reviewFieldErrors && reviewFieldErrors.rating) { %>
                        <p class="field-error"><%= reviewFieldErrors.rating %></p>
                      <% } %>
                    </div>

                    <div class="field">
                      <span>Your Review</span>
                      <textarea name="comment" rows="4" placeholder="Share your experience with this vehicle"><%= reviewForm.comment || '' %></textarea>
                      <% if (reviewFieldErrors && reviewFieldErrors.comment) { %>
                        <p class="field-error"><%= reviewFieldErrors.comment %></p>
                      <% } %>
                    </div>

                    <button class="auth-button" type="submit">Post Review</button>
                  </form>
                <% } %>

                <% if (reviews && reviews.length) { %>
                  <ul class="detail-error-list">
                    <% reviews.forEach((review) => { %>
                      <li>
                        <strong><%= review.user_name %></strong> · <%= review.rating %>/5
                        <p><%= review.comment %></p>

                        <% if (review.isOwner && currentUser) { %>
                          <form class="auth-form detail-form" action="/cars/<%= car.id %>/reviews/<%= review.id %>/edit" method="post">
                            <div class="field">
                              <span>Edit Rating</span>
                              <select name="rating">
                                <% [5, 4, 3, 2, 1].forEach((star) => { %>
                                  <option value="<%= star %>" <%= String(reviewForm.editingReviewId) === String(review.id) ? (String(reviewForm.rating) === String(star) ? 'selected' : '') : (String(review.rating) === String(star) ? 'selected' : '') %>><%= star %>/5</option>
                                <% }) %>
                              </select>
                            </div>
                            <div class="field">
                              <span>Edit Comment</span>
                              <textarea name="comment" rows="3"><%= String(reviewForm.editingReviewId) === String(review.id) ? (reviewForm.comment || '') : review.comment %></textarea>
                            </div>
                            <button class="auth-button" type="submit">Save Review</button>
                          </form>

                          <form class="auth-form detail-form" action="/cars/<%= car.id %>/reviews/<%= review.id %>/delete" method="post">
                            <button class="auth-button" type="submit">Delete Review</button>
                          </form>
                        <% } %>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p class="detail-copy">No reviews yet. Be the first to post one.</p>
                <% } %>
              </section>
            </div>
          </div>
  </div>
</section>